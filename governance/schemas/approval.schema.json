{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ra1nzzz/Dust-Mirror/governance/schemas/approval.schema.json",
  "title": "DustMirror threshold-signed governance approval",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "statement", "signatures"],
  "properties": {
    "schema_version": {"const": 1},
    "statement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ledger_repository", "stream", "approval_id", "kind", "sequence",
        "prev", "nonce", "issued_at", "expires_at", "source_repository",
        "source_repository_id", "source_revision", "source_tree",
        "workflow_path", "workflow_blob_sha", "workflow_run_id",
        "workflow_run_attempt", "checks", "target_repository",
        "target_repository_id", "target_ref", "target_base_revision",
        "target_base_tree", "sync_manifest_sha256",
        "ownership_catalog_sha256", "operations_sha256", "version", "tag",
        "artifact", "policy_epoch", "policy_sha256"
      ],
      "properties": {
        "ledger_repository": {"const": "ra1nzzz/Dust-Mirror"},
        "stream": {"enum": ["sync:dustmirror", "release:free", "release:pro"]},
        "approval_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{7,127}$"},
        "kind": {"enum": ["sync", "release_free", "release_pro"]},
        "sequence": {"type": "integer", "minimum": 1},
        "prev": {"$ref": "#/$defs/sha256"},
        "nonce": {"type": "string", "pattern": "^[A-Za-z0-9_-]+$"},
        "issued_at": {"type": "string", "format": "date-time", "pattern": "Z$"},
        "expires_at": {"type": "string", "format": "date-time", "pattern": "Z$"},
        "source_repository": {"type": "string", "minLength": 3},
        "source_repository_id": {"type": "integer", "minimum": 1},
        "source_revision": {"$ref": "#/$defs/git_sha"},
        "source_tree": {"$ref": "#/$defs/git_sha"},
        "workflow_path": {"type": "string", "pattern": "^\\.github/workflows/[A-Za-z0-9._/-]+\\.ya?ml$"},
        "workflow_blob_sha": {"$ref": "#/$defs/git_sha"},
        "workflow_run_id": {"type": "integer", "minimum": 1},
        "workflow_run_attempt": {"type": "integer", "minimum": 1},
        "checks": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/check"}
        },
        "target_repository": {"type": "string", "minLength": 3},
        "target_repository_id": {"type": "integer", "minimum": 1},
        "target_ref": {"type": "string", "pattern": "^refs/(heads|tags)/"},
        "target_base_revision": {"$ref": "#/$defs/git_sha"},
        "target_base_tree": {"$ref": "#/$defs/git_sha"},
        "sync_manifest_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "ownership_catalog_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "operations_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"},
        "tag": {"type": ["string", "null"]},
        "artifact": {"$ref": "#/$defs/artifact"},
        "policy_epoch": {"type": "integer", "minimum": 1},
        "policy_sha256": {"$ref": "#/$defs/sha256"}
      },
      "allOf": [
        {
          "if": {"properties": {"kind": {"const": "sync"}}},
          "then": {
            "properties": {
              "stream": {"const": "sync:dustmirror"},
              "tag": {"type": "null"},
              "sync_manifest_sha256": {"$ref": "#/$defs/sha256"},
              "ownership_catalog_sha256": {"$ref": "#/$defs/sha256"},
              "operations_sha256": {"$ref": "#/$defs/sha256"}
            }
          }
        },
        {
          "if": {"properties": {"kind": {"enum": ["release_free", "release_pro"]}}},
          "then": {
            "properties": {
              "tag": {"type": "string", "minLength": 2},
              "sync_manifest_sha256": {"type": "null"},
              "ownership_catalog_sha256": {"type": "null"},
              "operations_sha256": {"type": "null"}
            }
          }
        }
      ]
    },
    "signatures": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/signature"}
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sha256", "size_bytes"],
      "properties": {
        "name": {"type": "string", "minLength": 1, "maxLength": 255},
        "sha256": {"$ref": "#/$defs/sha256"},
        "size_bytes": {"type": "integer", "minimum": 1}
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "conclusion", "head_sha", "app_slug"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "conclusion": {"const": "success"},
        "head_sha": {"$ref": "#/$defs/git_sha"},
        "app_slug": {"type": "string", "minLength": 1}
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_id", "algorithm", "signature_b64"],
      "properties": {
        "key_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"},
        "algorithm": {"const": "ed25519"},
        "signature_b64": {"type": "string", "pattern": "^[A-Za-z0-9+/]{86}==$"}
      }
    }
  }
}
